# Required — API credentials
EASYDNS_TOKEN=
EASYDNS_API_KEY=

# Optional — default domain for tools
EASYDNS_DOMAIN=

# Safety flags (all default to restrictive)
EASYDNS_SANDBOX=true
EASYDNS_ENABLE_WRITES=false
EASYDNS_ALLOW_PRODUCTION=false
EASYDNS_ALLOW_DOMAIN_DELETE=false
EASYDNS_ALLOW_USER_MUTATIONS=false

# Domain filtering
EASYDNS_ALLOWED_DOMAINS=
EASYDNS_PROTECTED_DOMAINS=
