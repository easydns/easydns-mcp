# easyDNS MCP Server Configuration
# Copy this to .env and fill in your credentials

# Required — API credentials (from easyDNS control panel)
EASYDNS_TOKEN=
EASYDNS_API_KEY=

# Optional — default domain (used when no domain specified)
EASYDNS_DOMAIN=

# Safety flags — all default to restrictive settings
EASYDNS_SANDBOX=true              # Use sandbox API (default: true)
EASYDNS_ENABLE_WRITES=false       # Allow write operations (default: false)
EASYDNS_ALLOW_PRODUCTION=false    # Allow production API (default: false)
EASYDNS_ALLOW_DOMAIN_DELETE=false # Allow domain deletion (default: false)
EASYDNS_ALLOW_USER_MUTATIONS=false # Allow user account changes (default: false)

# Domain filtering — comma-separated lists
EASYDNS_ALLOWED_DOMAINS=          # Only these domains (empty = all allowed)
EASYDNS_PROTECTED_DOMAINS=        # Never modify these domains
